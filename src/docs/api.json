    "/api/v1/openai-activity-logs": {
      "get": {
        "operationId": "OpenAIActivityLogController_list",
        "parameters": [
          {
            "name": "page",
            "required": false,
            "in": "query",
            "schema": { "default": 1, "type": "number" }
          },
          {
            "name": "limit",
            "required": false,
            "in": "query",
            "schema": { "default": 10, "type": "number" }
          },
          {
            "name": "userIds",
            "required": false,
            "in": "query",
            "description": "Filter by user IDs",
            "schema": { "type": "array", "items": { "type": "string" } }
          },
          {
            "name": "userNames",
            "required": false,
            "in": "query",
            "description": "Filter by user names",
            "schema": { "type": "array", "items": { "type": "string" } }
          },
          {
            "name": "accountIds",
            "required": false,
            "in": "query",
            "description": "Filter by account IDs",
