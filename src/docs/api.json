      "get": {
        "operationId": "AdminController_listRules",
        "parameters": [
          {
            "name": "page",
            "required": false,
            "in": "query",
            "schema": { "default": 1, "type": "number" }
          },
          {
            "name": "limit",
            "required": false,
            "in": "query",
            "schema": { "default": 20, "type": "number" }
          },
          {
            "name": "text",
            "required": false,
            "in": "query",
            "description": "Filter by rule title text (matches bannedContent)",
            "schema": { "type": "string" }
          },
          {
            "name": "severity",
            "required": false,
            "in": "query",
            "schema": {
              "type": "string",
              "enum": ["Leve", "Moderada", "Grave", "Emergencia"]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AdminListRulesResponseDto"
                }
              }
            }
          }
        },
        "security": [{ "bearer": [] }],
        "summary": "List rules with filters by text (title) and severity",
        "tags": ["admin"]
      }
    },
    "/api/v1/admin/accounts/{accountId}/rules": {
      "post": {
        "operationId": "AdminController_createRule",
        "parameters": [
          {
            "name": "accountId",
            "required": true,
            "in": "path",
            "schema": { "type": "number" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateRuleDto" }
            }
          }
        },
        "responses": { "201": { "description": "Rule created." } },
        "security": [{ "bearer": [] }],
        "summary": "Create a rule for the selected account",
        "tags": ["admin"]
      }
    },
    "/api/v1/admin/accounts/{accountId}/rules/{ruleId}": {
      "put": {
        "operationId": "AdminController_updateRule",
        "parameters": [
          {
            "name": "accountId",
            "required": true,
            "in": "path",
            "schema": { "type": "number" }
          },
          {
            "name": "ruleId",
            "required": true,
            "in": "path",
            "schema": { "type": "number" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UpdateRuleDto" }
            }
          }
        },
        "responses": { "200": { "description": "Rule updated." } },
        "security": [{ "bearer": [] }],
        "summary": "Edit a rule for the selected account",
        "tags": ["admin"]
      }
    },
    "/api/v1/admin/rules/{ruleId}": {
      "delete": {
        "operationId": "AdminController_removeRule",
        "parameters": [
          {
            "name": "ruleId",
            "required": true,
            "in": "path",
            "schema": { "type": "number" }
          }
        ],
        "responses": { "204": { "description": "Rule deleted." } },
        "security": [{ "bearer": [] }],
        "summary": "Delete a rule",
        "tags": ["admin"]
      }
    },
    "/api/v1/user-notifications/{notificationId}": {
      "patch": {
        "operationId": "UserNotificationsController_updateRead",
        "parameters": [
          {
            "name": "notificationId",
            "required": true,
            "in": "path",
            "schema": { "type": "number" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateUserNotificationDto"
              }
            }
          }
        },
        "responses": { "200": { "description": "Notification updated." } },
        "security": [{ "bearer": [] }],
        "summary": "Update notification read status",
        "tags": ["user-notifications"]
      }
    }
  },
  "info": {
    "title": "Socrates API",
    "description": "Auth and user management API. Use integer identifiers.",
    "version": "1.0",
    "contact": {}
  },
  "tags": [
    { "name": "auth", "description": "Authentication and token lifecycle" },
    { "name": "users", "description": "User management" },
    { "name": "secret-objects", "description": "Secret object catalog" },
    { "name": "rules", "description": "User rules" },
    { "name": "openai", "description": "OpenAI queries" }
  ],
  "servers": [],
  "components": {
    "securitySchemes": {
      "bearer": { "scheme": "bearer", "bearerFormat": "JWT", "type": "http" }
    },
    "schemas": {
      "CreateUserDto": {
        "type": "object",
        "properties": {
          "fullName": { "type": "string", "example": "Hijo Perez" },
          "birthday": { "type": "string", "example": "2015-06-20" }
        },
        "required": ["fullName", "birthday"]
      },
      "UserResponseDto": {
        "type": "object",
        "properties": {
          "id": { "type": "number", "example": 1 },
          "fullName": { "type": "string" },
          "birthday": { "type": "string", "example": "2015-06-20" },
          "role": {
            "type": "string",
            "enum": ["PARENT", "CHILD", "ADMIN"],
            "example": "CHILD"
          },
          "accountId": { "type": "number", "example": 1 },
          "parentUserId": { "type": "number", "example": 1 },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" },
          "hasSecretObject": { "type": "boolean", "example": true }
        },
        "required": ["id", "fullName", "role", "createdAt", "updatedAt"]
      },
      "UpdateUserDto": {
        "type": "object",
        "properties": {
          "fullName": { "type": "string" },
          "birthday": { "type": "string", "example": "2015-06-20" }
        }
      },
      "LoginDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "description": "The email of the user",
            "example": "user@example.com"
          },
          "password": {
            "type": "string",
            "description": "The password of the user",
            "example": "password123"
          }
        },
        "required": ["email", "password"]
      },
      "AccountSnapshotDto": {
        "type": "object",
        "properties": {
          "id": { "type": "number", "example": 1 },
          "name": { "type": "string", "example": "My Account" },
          "email": { "type": "string", "example": "admin@example.com" }
        },
        "required": ["id", "name", "email"]
      },
      "AccountLoginResponseDto": {
        "type": "object",
        "properties": {
          "auth": { "type": "boolean", "example": true },
          "token": {
            "type": "string",
            "description": "Account session token (JWT)",
            "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
          },
          "refreshToken": {
            "type": "string",
            "description": "Refresh token (JWT)",
            "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
          },
          "account": { "$ref": "#/components/schemas/AccountSnapshotDto" }
        },
        "required": ["auth", "token", "refreshToken", "account"]
      },
      "SelectProfileDto": {
        "type": "object",
        "properties": {
          "userId": { "type": "number", "example": 123 },
          "pin": {
            "type": "string",
            "description": "Required only if selected profile role is PARENT",
            "example": "1234"
          },
          "secretObjectId": {
            "type": "number",
            "description": "Required only if selected profile role is CHILD",
            "example": 3
          }
        },
        "required": ["userId"]
      },
      "LoginResponseDto": {
        "type": "object",
        "properties": {
          "auth": { "type": "boolean", "example": true },
          "token": {
            "type": "string",
            "description": "Access token (JWT)",
            "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
          },
          "refreshToken": {
            "type": "string",
            "description": "Refresh token (JWT)",
            "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
          },
          "role": {
            "type": "string",
            "enum": ["PARENT", "CHILD", "ADMIN"],
            "example": "CHILD"
          }
        },
        "required": ["auth", "token", "refreshToken", "role"]
      },
      "AssignSecretObjectDto": {
        "type": "object",
        "properties": {
          "userId": { "type": "number", "example": 12 },
          "objectId": { "type": "number", "example": 3 }
        },
        "required": ["userId", "objectId"]
      },
      "RefreshTokenDto": {
        "type": "object",
        "properties": {
          "refreshToken": {
            "type": "string",
            "description": "Refresh token issued during login",
            "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
          }
        },
        "required": ["refreshToken"]
      },
      "RefreshTokenResponseDto": {
        "type": "object",
        "properties": {
          "auth": { "type": "boolean", "example": true },
          "token": {
            "type": "string",
            "description": "Access token (JWT)",
            "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
          },
          "refreshToken": {
            "type": "string",
            "description": "Refresh token (JWT)",
            "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
          },
          "role": {
            "type": "string",
            "enum": ["PARENT", "CHILD", "ADMIN"],
            "example": "CHILD",
            "description": "Present only for profile sessions (select-profile refresh flow)."
          }
        },
        "required": ["auth", "token", "refreshToken"]
      },
      "SignupDto": {
        "type": "object",
        "properties": {
          "accountName": { "type": "string", "example": "My Account" },
          "email": { "type": "string", "example": "admin@example.com" },
          "fullName": { "type": "string", "example": "Juan Perez" },
          "birthday": { "type": "string", "example": "1985-02-10" },
          "password": { "type": "string", "example": "password123" },
          "pin": { "type": "string", "example": "1234" }
        },
        "required": [
          "accountName",
          "email",
          "fullName",
          "birthday",
          "password",
          "pin"
        ]
      },
      "SignupResponseDto": {
        "type": "object",
        "properties": {
          "auth": { "type": "boolean", "example": true },
          "token": {
            "type": "string",
            "description": "Account session token (JWT)",
            "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
          },
          "refreshToken": {
            "type": "string",
            "description": "Refresh token (JWT)",
            "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
          },
          "account": { "$ref": "#/components/schemas/AccountSnapshotDto" },
          "userId": { "type": "number", "example": 123 }
        },
        "required": ["auth", "token", "refreshToken", "account", "userId"]
      },
      "SecretObjectResponseDto": {
        "type": "object",
        "properties": {
          "id": { "type": "number", "example": 1 },
          "imageUrl": {
            "type": "string",
            "example": "https://cdn.example.com/secret-objects/rocket.png"
          }
        },
        "required": ["id", "imageUrl"]
      },
      "OpenAiQueryDto": {
        "type": "object",
        "properties": {
          "input": {
            "type": "string",
            "description": "User input for the model"
          },
          "conversationThreadId": {
            "type": "number",
            "description": "Optional conversation id to continue a specific conversation",
            "example": 12
          },
          "newConversation": {
            "type": "boolean",
            "description": "When true, starts a brand new conversation",
            "example": false
          }
        },
        "required": ["input"]
      },
      "CreateRuleDto": {
        "type": "object",
        "properties": {
          "bannedContent": {
            "type": "string",
            "description": "Banned content"
          },
          "severity": {
            "type": "string",
            "enum": ["Leve", "Moderada", "Grave", "Emergencia"],
            "default": "Leve"
          },
          "responseType": {
            "type": "string",
            "enum": [
              "Responder normalmente",
              "Responder y sugerir hablar con un adulto",
              "No responder y sugerir hablar con un adulto",
              "Ante emergencias ayuda y avisa que se solicitara ayuda a un adulto"
            ],
            "default": "Responder normalmente"
          },
          "isBlocking": { "type": "boolean", "default": false },
          "notify": { "type": "boolean", "default": false },
          "typeOfNotification": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["IN_APP", "PUSH_NOTIFICATION", "EMAIL"]
            }
          }
        },
        "required": ["bannedContent"]
      },
      "UpdateRuleDto": {
        "type": "object",
        "properties": {
          "bannedContent": {
            "type": "string",
            "description": "Banned content"
          },
          "severity": {
            "type": "string",
            "enum": ["Leve", "Moderada", "Grave", "Emergencia"]
          },
          "responseType": {
            "type": "string",
            "enum": [
              "Responder normalmente",
              "Responder y sugerir hablar con un adulto",
              "No responder y sugerir hablar con un adulto",
              "Ante emergencias ayuda y avisa que se solicitara ayuda a un adulto"
            ]
          },
          "isBlocking": { "type": "boolean" },
          "notify": { "type": "boolean" },
          "typeOfNotification": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["IN_APP", "PUSH_NOTIFICATION", "EMAIL"]
            }
          }
        }
      },
      "AssignRuleDto": {
        "type": "object",
        "properties": { "userId": { "type": "number", "example": 1 } },
        "required": ["userId"]
      },
      "CreateNotificationDto": {
        "type": "object",
        "properties": {
          "title": { "type": "string" },
          "message": { "type": "string" },
          "userIds": {
            "description": "Assign to user ids",
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "required": ["title", "message"]
      },
      "UpdateNotificationDto": {
        "type": "object",
        "properties": {
          "title": { "type": "string" },
          "message": { "type": "string" }
        }
      },
      "AssignNotificationDto": {
        "type": "object",
        "properties": { "userId": { "type": "number", "example": 1 } },
        "required": ["userId"]
      },
      "TestEmailDto": {
        "type": "object",
        "properties": { "email": { "type": "string" } },
        "required": ["email"]
      },
      "AdminUserListItemDto": {
        "type": "object",
        "properties": {
          "userId": { "type": "number", "example": 10 },
          "fullName": { "type": "string", "example": "Jane Doe" },
          "birthday": { "type": "string", "example": "2013-05-10" },
          "role": {
            "type": "string",
            "enum": ["PARENT", "CHILD", "ADMIN"],
            "example": "CHILD"
          },
          "accountId": { "type": "number", "example": 3 },
          "accountName": { "type": "string", "example": "Household Doe" },
          "accountEmail": { "type": "string", "example": "parent@example.com" },
          "isActive": { "type": "boolean", "example": true },
          "canUseAI": { "type": "boolean", "example": true },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" }
        },
        "required": [
          "userId",
          "fullName",
          "role",
          "accountId",
          "accountName",
          "accountEmail",
          "isActive",
          "canUseAI",
          "createdAt",
          "updatedAt"
        ]
      },
      "AdminListUsersResponseDto": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/AdminUserListItemDto" }
          },
          "total": { "type": "number", "example": 53 },
          "page": { "type": "number", "example": 1 },
          "limit": { "type": "number", "example": 20 }
        },
        "required": ["items", "total", "page", "limit"]
      },
      "UpdateAccountSettingsDto": {
        "type": "object",
        "properties": {
          "isActive": { "type": "boolean", "example": false },
          "canUseAI": { "type": "boolean", "example": true }
        }
      },
      "UpdateAccountSettingsResponseDto": {
        "type": "object",
        "properties": {
          "userId": { "type": "number", "example": 4 },
          "accountId": { "type": "number", "example": 2 },
          "isActive": { "type": "boolean", "example": true },
          "canUseAI": { "type": "boolean", "example": true }
        },
        "required": ["userId", "accountId", "isActive", "canUseAI"]
      },
      "AdminExportResponseDto": {
        "type": "object",
        "properties": {
          "fileName": {
            "type": "string",
            "example": "parents-2026-03-04.xlsx"
          },
          "mimeType": {
            "type": "string",
            "example": "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet"
          },
          "fileBase64": {
            "type": "string",
            "description": "Base64 encoded XLSX file content"
          }
        },
        "required": ["fileName", "mimeType", "fileBase64"]
      },
      "AdminRuleListItemDto": {
        "type": "object",
        "properties": {
          "id": { "type": "number", "example": 1 },
          "accountId": { "type": "number", "example": 3 },
          "bannedContent": { "type": "string", "example": "Violencia" },
          "severity": {
            "type": "string",
            "enum": ["Leve", "Moderada", "Grave", "Emergencia"]
          },
          "responseType": {
            "type": "string",
            "enum": [
              "Responder normalmente",
              "Responder y sugerir hablar con un adulto",
              "No responder y sugerir hablar con un adulto",
              "Ante emergencias ayuda y avisa que se solicitara ayuda a un adulto"
            ]
          },
          "isBlocking": { "type": "boolean", "example": false },
          "notify": { "type": "boolean", "example": true },
          "typeOfNotification": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["IN_APP", "PUSH_NOTIFICATION", "EMAIL"]
            }
          },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" }
        },
        "required": [
          "id",
          "accountId",
          "bannedContent",
          "severity",
          "responseType",
          "isBlocking",
          "notify",
          "createdAt",
          "updatedAt"
        ]
      },
      "AdminListRulesResponseDto": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/AdminRuleListItemDto" }
          },
          "total": { "type": "number", "example": 10 },
          "page": { "type": "number", "example": 1 },
          "limit": { "type": "number", "example": 20 }
        },
        "required": ["items", "total", "page", "limit"]
      },
      "UpdateUserNotificationDto": {
        "type": "object",
        "properties": { "read": { "type": "boolean" } },
        "required": ["read"]
      }
    }
  }
}
