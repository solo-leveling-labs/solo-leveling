          },
          {
            "name": "accountNames",
            "required": false,
            "in": "query",
            "description": "Filter by account names",
            "schema": { "type": "array", "items": { "type": "string" } }
          },
          {
            "name": "createdAtFrom",
            "required": false,
            "in": "query",
            "description": "Start date (inclusive) for createdAt filter (ISO string)",
            "schema": { "type": "string" }
          },
          {
            "name": "createdAtTo",
            "required": false,
            "in": "query",
            "description": "End date (inclusive) for createdAt filter (ISO string)",
            "schema": { "type": "string" }
          },
          {
            "name": "actionTypes",
            "required": false,
            "in": "query",
            "description": "Filter by action types",
            "schema": { "type": "array", "items": { "type": "string" } }
          }
        ],
        "responses": {
          "200": { "description": "Successfully retrieved logs" },
          "401": { "description": "Unauthorized / Invalid token" },
          "403": { "description": "Forbidden" }
        },
        "security": [{ "bearer": [] }],
        "summary": "List all OpenAI activity logs (Admin only)",
        "tags": ["OpenAI Activity Logs"]
      }
    },
